# Étape 4: Créer des timestamps complets pour le sommeil

print("4. Création des timestamps...", end=" ")

def combiner(date, heure):
    """Combine une date et une heure pour créer un timestamp complet"""
    
    if pd.isna(date) or pd.isna(heure):
        return pd.NaT
    
    date = pd.to_datetime(date)
    
    if isinstance(heure, pd.Timestamp):
        return heure
    
    heure_str = str(heure) #convertir en chaîne de caractères
    parts = heure_str.split(':')  #découper la chaîne par le caractère :
    
    h = int(parts[0]) #premier élément de la liste (les heures)
    m = int(parts[1]) if len(parts) > 1 else 0
    
    return date + pd.Timedelta(hours=h, minutes=m)

# Appliquer sur chaque ligne
df_sommeil['ts_coucher'] = df_sommeil.apply(
    lambda x: combiner(x['Start day'], x['Fell asleep']),
    axis=1
)

df_sommeil['ts_reveil'] = df_sommeil.apply(
    lambda x: combiner(x['End day'], x['Woke up']),
    axis=1
)

print("OK")

# Étape 5: Déterminer le statut de sommeil pour chaque minute

print("5. Attribution du statut de sommeil...", end=" ")
def check_sommeil(timestamp, periodes):
    """
    Vérifie si à ce timestamp, la personne dormait
    
    IMPORTANT: 
    - ts_coucher = moment où la personne se couche (pas encore endormie)
    - Le sommeil commence APRÈS ts_coucher
    - ts_reveil = moment du réveil (encore endormie à cet instant)
    """
    
    for _, p in periodes.iterrows():
        if pd.notna(p['ts_coucher']) and pd.notna(p['ts_reveil']):
            
            # Sommeil = APRÈS coucher et JUSQU'AU réveil inclus
            if p['ts_coucher'] < timestamp <= p['ts_reveil']:
                return 'Endormi'
    
    return 'Éveillé'

# Appliquer à chaque minute
df_mtn['statut'] = df_mtn['timestamp'].apply(
    lambda ts: check_sommeil(ts, df_sommeil)
)

